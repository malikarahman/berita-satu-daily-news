{
  "name": "berita-satu-daily-news",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx -r tsconfig-paths/register prisma/seed.ts",
    "setup": "test -f .env || cp .env.example .env; npm install && prisma generate && prisma migrate dev --name init && npm run db:seed",
    "schedule": "tsx -r tsconfig-paths/register scripts/scheduler.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.468.0",
    "next": "^14.2.23",
    "node-cron": "^3.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.23",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
