generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Article {
  id                       Int           @id @default(autoincrement())
  sourceName               String        @map("source_name")
  sourceUrl                String        @map("source_url")
  category                 String
  location                 String
  date                     DateTime
  dayName                  String        @map("day_name")
  title                    String
  previewText              String        @map("preview_text")
  bodyText                 String        @map("body_text")
  weatherPayloadJson       String        @map("weather_payload_json")
  draftUrl                 String?       @map("draft_url")
  runType                  String        @map("run_type")
  triggeredBy              String        @map("triggered_by")
  generationTime           DateTime      @map("generation_time")
  requestedPublishDatetime DateTime      @map("requested_publish_datetime")
  status                   String        @default("Pending Review")
  editorName               String?       @map("editor_name")
  notes                    String?
  createdAt                DateTime      @default(now()) @map("created_at")
  updatedAt                DateTime      @updatedAt @map("updated_at")
  activityLogs             ActivityLog[]

  @@index([date])
  @@index([location])
  @@index([status])
  @@index([runType])
  @@map("articles")
}

model ActivityLog {
  id             Int      @id @default(autoincrement())
  articleId      Int      @map("article_id")
  action         String
  previousStatus String?  @map("previous_status")
  newStatus      String?  @map("new_status")
  actorName      String   @map("actor_name")
  note           String?
  createdAt      DateTime @default(now()) @map("created_at")
  article        Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@map("activity_logs")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  level     String
  scope     String
  message   String
  metadata  String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([level])
  @@index([scope])
  @@map("system_logs")
}
