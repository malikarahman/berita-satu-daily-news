generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Article {
  id                       Int           @id @default(autoincrement())
  sourceName               String        @map("source_name")
  sourceUrl                String        @map("source_url")
  dataSource               String        @default("BMKG") @map("data_source")
  category                 String
  location                 String
  date                     DateTime
  dayName                  String        @map("day_name")
  title                    String
  previewText              String        @map("preview_text")
  bodyText                 String        @map("body_text")
  weatherPayloadJson       String        @map("weather_payload_json")
  draftUrl                 String?       @map("draft_url")
  templatePreference       String?       @map("template_preference")
  selectedTemplate         String?       @map("selected_template")
  editorialNotes           String?       @map("editorial_notes")
  dataCompletenessNote     String?       @map("data_completeness_note")
  runType                  String        @map("run_type")
  triggeredBy              String        @map("triggered_by")
  generationTime           DateTime      @map("generation_time")
  requestedPublishDatetime DateTime      @map("requested_publish_datetime")
  status                   String        @default("Pending Review")
  editorName               String?       @map("editor_name")
  notes                    String?
  createdAt                DateTime      @default(now()) @map("created_at")
  updatedAt                DateTime      @updatedAt @map("updated_at")
  activityLogs             ActivityLog[]
  errorLogs                ErrorLog[]

  @@index([date])
  @@index([location])
  @@index([status])
  @@index([runType])
  @@map("articles")
}

model ActivityLog {
  id             Int      @id @default(autoincrement())
  articleId      Int      @map("article_id")
  action         String
  previousStatus String?  @map("previous_status")
  newStatus      String?  @map("new_status")
  actorName      String   @map("actor_name")
  note           String?
  createdAt      DateTime @default(now()) @map("created_at")
  article        Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@map("activity_logs")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model ErrorLog {
  id               Int       @id @default(autoincrement())
  errorType        String    @map("error_type")
  module           String
  action           String
  message          String
  technicalDetails String?   @map("technical_details")
  articleId        Int?      @map("article_id")
  location         String?
  sourceUrl        String?   @map("source_url")
  actor            String?
  result           String?
  createdAt        DateTime  @default(now()) @map("created_at")
  article          Article?  @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@index([module])
  @@index([action])
  @@index([articleId])
  @@index([location])
  @@map("error_logs")
}
